{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tribe/facetwp-archive",
	"version": "0.1.0",
	"title": "FacetWP Archive",
	"category": "theme",
	"icon": "welcome-widgets-menus",
	"description": "An archive template powered by FacetWP",
	"attributes": {
		"filterBarPosition": {
			"type": "string",
			"default": "top",
			"enum": [ "top", "sidebar" ]
		}
	},
	"providesContext": {
		"tribe/facetwp-archive/filterBarPosition": "filterBarPosition"
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"grid",
			"full"
		],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "tribe",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
