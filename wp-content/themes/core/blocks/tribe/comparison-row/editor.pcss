/* -------------------------------------------------------------------------
 *
 * Block - Comparison Row - Editor-only Styles
 *
 * ------------------------------------------------------------------------- */

.wp-block-tribe-comparison-row-editor.is-sidebar-only {
	display: none;
}

.wp-block-tribe-comparison-row-editor__inspector-cell {
	display: grid;
	padding-bottom: var(--spacer-20);
	margin-bottom: var(--spacer-20);
	border-bottom: 1px solid var(--color-neutral-30);

	&:last-child {
		padding-bottom: 0;
		margin-bottom: 0;
		border-bottom: 0;
	}
}

.wp-block-tribe-comparison-row-editor__inspector-cell-label {
	margin: 0 0 16px;
	font-size: var(--font-size-20);
	font-weight: 600;
	line-height: 1.3;
}

.wp-block-tribe-comparison-row-editor__cell-type.components-radio-control
	.components-v-stack {
	flex-direction: row;
	flex-wrap: wrap;
	justify-content: flex-start;
	gap: var(--spacer-10) var(--spacer-20);
}

.wp-block-tribe-comparison-row-editor__inspector-cell .components-text-control__input {
	width: 100%;
}
