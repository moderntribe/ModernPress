/* -------------------------------------------------------------------------
 *
 * Integrations: FacetWP
 *
 * ------------------------------------------------------------------------- */

/**
 * Give all selectors context so we can override them. Edit this selector to
 * target more wrapper elements that could contain FacetWP facets.
 */
.b-facetwp-filter-bar,
.b-facetwp-grid {

	/* -----------------------------------------------------------------------
	 * FacetWP - Facets
	 * ----------------------------------------------------------------------- */

	.facetwp-facet {
		margin-bottom: 0;
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Facet Wrapper
	 * ----------------------------------------------------------------------- */

	.fs-wrap {
		display: block;
		width: 100%;
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Facet - fSelect
	 *
	 * The fSelect dropdown always uses a "white" color theme, so there's no
	 * need to define any color variables for it.
	 * ----------------------------------------------------------------------- */

	.facetwp-type-fselect {
		--chevron-size: 15px;

		.fs-wrap {
			cursor: default;
			border-radius: var(--border-radius-s);

			&:focus-visible {

				@mixin focus-visible;
			}
		}

		.fs-label-wrap {
			width: 100%;
			position: relative;

			/* right padding = icon size + spacer */
			padding: 9px calc(var(--spacer-20) * 2 + var(--chevron-size)) 9px var(--spacer-20);
			border: 1px solid var(--color-border);
			border-radius: var(--border-radius-s);
			background-color: var(--color-white);
			color: var(--color-black);
			cursor: pointer;

			.fs-label {

				@mixin t-body;
				padding: 0;
			}

			.fs-arrow {
				width: var(--chevron-size);
				height: var(--chevron-size);
				position: absolute;
				right: var(--spacer-20);
				top: 50%;
				bottom: auto;
				transform: translateY(-50%) rotate(90deg);
				background: none;
				background-color: var(--color-black);
				border: 0;
				mask: var(--icon-chevron-right) center no-repeat;
				mask-size: contain;

				.fs-open & {
					transform: translateY(-50%) rotate(-90deg);
				}
			}
		}

		.fs-dropdown {
			margin-top: var(--spacer-10);
			border: 1px solid var(--color-black);
			border-radius: var(--border-radius-s);
			background-color: var(--color-white);
			color: var(--color-black);
		}

		.fs-search {
			--search-icon-size: 24px;
			position: relative;
			padding: 0;
			border-top-left-radius: var(--border-radius-s);
			border-top-right-radius: var(--border-radius-s);
			border-bottom: 1px solid var(--color-black);
			overflow: hidden;

			input[type="text"] {

				@mixin t-body;
				position: relative;
				z-index: 1;

				/* right padding = icon size + spacer */
				padding: 10px calc(var(--spacer-20) * 2 + var(--search-icon-size)) 10px var(--spacer-20);
				border: 0;
				border-radius: 0;
				background-color: var(--color-neutral-10);
				color: var(--color-black);
			}

			&::after {
				content: "";
				display: block;
				width: var(--search-icon-size);
				height: var(--search-icon-size);
				position: absolute;
				right: var(--spacer-20);
				top: 50%;
				transform: translateY(-50%);
				z-index: 2;
				background-color: var(--color-neutral-50);
				mask: var(--icon-search) center no-repeat;
				mask-size: contain;
			}
		}

		.fs-options {
			max-height: 275px;
			scrollbar-color: var(--color-neutral-50) var(--color-neutral-30);
			scrollbar-width: thin;

			.fs-option {
				--checkbox-size: 24px;

				/* top and bottom padding = half of the spacer-30 (helps each item have a larger click target)
				   left padding = spacer-20 + checkbox size + spacer-10 [label displays here] */
				padding: calc(var(--spacer-30) / 2) var(--spacer-20) calc(var(--spacer-30) / 2) calc(var(--spacer-20) + var(--spacer-10) + var(--checkbox-size));

				.fs-checkbox {
					width: var(--checkbox-size);
					height: var(--checkbox-size);
					position: absolute;
					left: var(--spacer-20);
					top: 50%;
					transform: translateY(-50%);
					background: none;
					border: 1px solid var(--color-neutral-30);
					border-radius: 0;
					background-color: var(--color-white);
					transition: var(--transition);

					i {
						display: none;
					}
				}

				.fs-option-label {

					@mixin t-animated-underline;
					@mixin t-body;
				}

				&.selected {

					.fs-checkbox {
						border-color: var(--color-black);
						background: var(--color-white) var(--icon-list-check) center no-repeat;
						background-size: 14px 12px;
					}

					.fs-option-label {
						font-weight: var(--font-weight-bold);
					}
				}

				@media (--has-hover) {

					&:hover {

						@mixin int-facetwp-fselect-hover-focus;
					}
				}

				&:focus:not(:focus-visible),
				&:focus-visible {

					@mixin int-facetwp-fselect-hover-focus;
				}

				&:focus-visible {
					outline-color: var(--color-border);
				}
			}
		}

		.fs-actions {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: var(--spacer-20);
			border-top: 1px solid var(--color-black);
		}
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Facet - Dropdown
	 * ----------------------------------------------------------------------- */

	.facetwp-dropdown {

		@mixin t-body;
		--chevron-size: 15px;
		appearance: none;
		width: 100%;
		position: relative;

		/* right padding = icon size + spacer */
		padding: 9px calc(var(--spacer-20) * 2 + var(--chevron-size)) 9px var(--spacer-20);
		border: 1px solid var(--color-border);
		border-radius: var(--border-radius-s);
		background: var(--color-white) var(--icon-select-chevron) right var(--spacer-20) center no-repeat;
		background-size: 14px 8px;
		color: var(--color-black);
		cursor: pointer;

		&:focus-visible {

			@mixin focus-visible;
		}
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Facet - Search
	 * ----------------------------------------------------------------------- */

	.facetwp-type-search {

		.facetwp-input-wrap {
			display: block;
			width: 100%;
		}

		.facetwp-icon {
			right: var(--spacer-20);
			opacity: 1;

			&::before {
				width: 24px;
				background: none;
				mask: var(--icon-search) center no-repeat;
				mask-size: contain;
				background-color: var(--fwp-search-icon-color);
				transform: none !important; /* stop FacetWP from rotating the icon */
			}
		}

		.facetwp-search {

			@mixin t-body;
			width: 100%;
			min-width: unset;
			padding: 9px var(--spacer-20);
			border: 1px solid transparent;
			border-radius: var(--border-radius-s);
			background-color: var(--fwp-search-background-color);
			color: var(--fwp-search-color);

			&:focus:not(:focus-visible),
			&:focus-visible,
			&:not(:placeholder-shown) {
				outline: none;
				border-color: var(--color-border);
				background-color: var(--fwp-search-active-background-color);
			}
		}
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Facet - Checkbox / Radio
	 * ----------------------------------------------------------------------- */

	.facetwp-checkbox,
	.facetwp-radio {

		@mixin t-body;
		--checkbox-size: 24px;
		position: relative;
		background: none !important; /* stop FacetWP from adding a background */
		margin-bottom: var(--spacer-20);
		padding-left: calc(var(--checkbox-size) + var(--spacer-20));

		&::before {
			content: "";
			display: block;
			width: var(--checkbox-size);
			height: var(--checkbox-size);
			position: absolute;
			left: 0;
			top: 3px;
			background-color: var(--fwp-checkbox-background-color);
			border: 1px solid var(--fwp-checkbox-border-color);
			transition: var(--transition);
		}

		.facetwp-display-value {

			@mixin t-animated-underline;
			padding-right: 0;
		}

		&[aria-checked="true"] {
			font-weight: var(--font-weight-bold);

			&::before {
				border-color: var(--fwp-checkbox-checked-border-color);
				background: var(--fwp-checkbox-checked-background-color) var(--icon-list-check) center no-repeat;
				background-size: 14px 12px;
			}
		}

		@media (--has-hover) {

			&:hover {

				@mixin int-facetwp-checkbox-hover-focus;
			}
		}

		&:focus:not(:focus-visible) {

			@mixin int-facetwp-checkbox-hover-focus;
		}

		&:focus-visible {

			@mixin focus-visible;
		}
	}

	.facetwp-radio {

		&::before {
			border-radius: 100%;
		}

		&[aria-checked="true"] {
			font-weight: var(--font-weight-bold);

			&::before {
				border-color: var(--fwp-radio-checked-border-color);
				background: var(--fwp-radio-checked-background-color);
				box-shadow: inset 0 0 0 6px var(--fwp-radio-checked-mark-color);
			}
		}
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Toggle
	 * ----------------------------------------------------------------------- */

	.facetwp-toggle {

		@mixin a-link;
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Reset
	 * ----------------------------------------------------------------------- */

	.facetwp-reset {

		@mixin a-link;
		border: 0;
		padding: 0;
	}

	/* -----------------------------------------------------------------------
	 * FacetWP - Pager
	 * ----------------------------------------------------------------------- */

	.facetwp-type-pager {

		.facetwp-pager {
			display: flex;
			align-items: center;
		}

		.facetwp-page {

			@mixin t-body;
			background: none;
			border: none;
			padding: 0;
			margin: 0;
			cursor: pointer;
			color: var(--fwp-pagination-color);
			text-decoration: none;
			transition: var(--transition);

			&:is(.dots) {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				border-radius: 100%;
				background-color: var(--fwp-pagination-numbers-background-color);
				margin: 0 var(--spacer-10);
				cursor: default;
			}

			&:is(.prev, .next) {
				display: flex;
				align-items: center;
				gap: 0;
				margin-right: calc(var(--spacer-40) - var(--spacer-10));
				font-size: 0;

				@container facetwp-archive (min-width: 992px) {
					gap: var(--spacer-20);
					font-size: inherit;
				}

				&::before {
					content: "";
					display: block;
					width: 10px;
					height: 16px;
					background-color: var(--fwp-pagination-color);
					mask: var(--icon-chevron-left) center no-repeat;
					mask-size: contain;
					transition: var(--transition);
				}

				span {

					@mixin t-animated-underline;
				}

				@media (--has-hover) {

					&:hover {

						@mixin int-facetwp-pager-prev-next-hover-focus;
					}
				}

				&:focus:not(:focus-visible) {

					@mixin int-facetwp-pager-prev-next-hover-focus;
				}

				&:focus-visible {

					@mixin focus-visible;
				}
			}

			&:is(.next) {
				flex-direction: row-reverse;
				margin-left: calc(var(--spacer-40) - var(--spacer-10));
				margin-right: 0;

				&::before {
					mask-image: var(--icon-chevron-right);
				}
			}

			&:not(.prev, .next, .dots) {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 40px;
				height: 40px;
				border-radius: 100%;
				background-color: var(--fwp-pagination-numbers-background-color);
				margin: 0 var(--spacer-10);

				@media (--has-hover) {

					&:hover {

						@mixin int-facetwp-pager-page-hover-focus;
					}
				}

				&:focus:not(:focus-visible) {

					@mixin int-facetwp-pager-page-hover-focus;
				}

				&:focus-visible {

					@mixin focus-visible;
				}

				&.active {
					background-color: var(--fwp-pagination-active-background-color);
					color: var(--fwp-pagination-active-color);
				}
			}
		}
	}
}


